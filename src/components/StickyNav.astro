---
import { Config } from "../config";
const { nav, site } = Config;
---

<nav class="sticky-nav" role="navigation" aria-label="Page sections">
  <div class="nav-inner container-wide">
    <!-- Site short title -->
    <span class="nav-site-title">{site.shortTitle}</span>

    <!-- Section links -->
    <div class="nav-links" role="list">
      {
        nav.map((item) => (
          <a
            href={`#${item.anchor}`}
            class="nav-link"
            data-anchor={item.anchor}
            role="listitem"
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Theme toggle -->
    <button
      class="theme-toggle"
      id="theme-toggle"
      type="button"
      data-theme-toggle
      aria-label="Toggle dark/light mode"
      aria-pressed="false"
      title="Toggle theme"
    >
      <span id="theme-icon" aria-hidden="true"></span>
    </button>
  </div>
</nav>

<script is:inline>
  // ─── Icons ───────────────────────────────────────────────────────────────
  const sunIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;
  const moonIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;

  // ─── Theme Toggle ─────────────────────────────────────────────────────────
  function getTheme() {
    return document.documentElement.getAttribute("data-theme") || "light";
  }

  function setTheme(theme) {
    document.documentElement.setAttribute("data-theme", theme);
    try {
      localStorage.setItem("theme", theme);
    } catch (error) {
      // Ignore storage failures and keep the theme change in-memory.
    }
    updateIcon(theme);
    updateButtonState(theme);
  }

  function updateIcon(theme) {
    const icon = document.getElementById("theme-icon");
    if (icon) icon.innerHTML = theme === "dark" ? sunIcon : moonIcon;
  }

  function updateButtonState(theme) {
    const button = document.getElementById("theme-toggle");
    if (button) button.setAttribute("aria-pressed", String(theme === "dark"));
  }

  function initThemeToggle() {
    const toggleBtn = document.getElementById("theme-toggle");
    if (toggleBtn && !toggleBtn.dataset.bound) {
      toggleBtn.dataset.bound = "true";
      toggleBtn.addEventListener("click", () => {
        setTheme(getTheme() === "dark" ? "light" : "dark");
      });
    }

    const theme = getTheme();
    updateIcon(theme);
    updateButtonState(theme);
  }

  initThemeToggle();
  document.addEventListener("astro:page-load", initThemeToggle);

  // ─── Active Section Tracking ──────────────────────────────────────────────
  const navLinks = document.querySelectorAll(".nav-link[data-anchor]");

  function updateActiveLink() {
    const scrollY = window.scrollY;
    const probeY = scrollY + window.innerHeight / 4;
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    let current = null;

    navLinks.forEach((link) => {
      const anchor = link.getAttribute("data-anchor");
      const section = document.getElementById(anchor);
      if (section) {
        const top = section.getBoundingClientRect().top + scrollY;
        if (probeY >= top) {
          current = anchor;
        }
      }
    });

    if (scrollY >= maxScroll - 1) {
      // At the true bottom of the page, the trailing sections may be too
      // short to ever reach the probe line above, so force the last item.
      current = navLinks[navLinks.length - 1].getAttribute("data-anchor");
    }

    navLinks.forEach((link) => {
      link.classList.toggle(
        "active",
        link.getAttribute("data-anchor") === current,
      );
    });
  }

  window.addEventListener("scroll", updateActiveLink, { passive: true });
  updateActiveLink();
</script>

<style>
  .nav-inner {
    display: flex;
    align-items: center;
    height: var(--nav-height);
    gap: 1rem;
  }

  .nav-site-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--text);
    white-space: nowrap;
    margin-right: auto;
    opacity: 0.85;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: nowrap;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .nav-links::-webkit-scrollbar {
    display: none;
  }

  @media (max-width: 1100px) {
    .nav-site-title {
      display: none;
    }
  }

  @media (max-width: 500px) {
    .nav-links {
      gap: 0;
      flex: 1;
      justify-content: flex-start;
    }
    .nav-link {
      padding: 0.375rem 0.5rem;
      font-size: 0.8rem;
    }
  }
</style>
