---
import { Config } from '../config';

const { hero, authors, actionButtons } = Config;
---

<section class="hero-section">
  <div class="container">
    <!-- Title -->
    <div class="hero-content animate-fade-up">
      {hero.venue && (
        <p class="venue-badge animate-fade-up animate-fade-up-1">{hero.venue}</p>
      )}
      <h1 class="hero-title animate-fade-up animate-fade-up-2">{hero.title}</h1>

      <!-- Authors -->
      <div class="authors animate-fade-up animate-fade-up-3">
        {authors.map((author, i) => (
          <span class="author-block">
            {author.url ? (
              <a href={author.url} target="_blank" rel="noopener noreferrer" class="author-name">
                {author.name}
              </a>
            ) : (
              <span class="author-name">{author.name}</span>
            )}
            {author.contact && (
              author.contactUrl ? (
                <a href={author.contactUrl} target="_blank" rel="noopener noreferrer" class="author-contact">
                  {author.contact}
                </a>
              ) : author.contact.includes('@') ? (
                <a href={`mailto:${author.contact}`} class="author-contact">
                  {author.contact}
                </a>
              ) : (
                <span class="author-contact">{author.contact}</span>
              )
            )}
            <a href={author.affiliationUrl} target="_blank" rel="noopener noreferrer" class="affiliation-link">
              {author.affiliation}
            </a>
          </span>
        ))}
      </div>

      <!-- Action Buttons -->
      <div class="action-buttons animate-fade-up animate-fade-up-4">
        {actionButtons.map((btn) => (
          <a
            href={btn.url}
            class={btn.primary ? 'btn-primary' : 'btn-secondary'}
            target={btn.url.startsWith('http') ? '_blank' : '_self'}
            rel={btn.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            <span class="btn-icon" data-icon={btn.icon} aria-hidden="true"></span>
            {btn.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Teaser Video -->
    <div class="teaser-video-wrapper animate-fade-up animate-fade-up-5">
      <video
        autoplay
        muted
        loop
        playsinline
        class="teaser-video"
        aria-label="Teaser video"
      >
        <source src={hero.teaserVideo.webm} type="video/webm" />
        <source src={hero.teaserVideo.mp4} type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>

<!-- Inline SVG icons for buttons -->
<script is:inline>
  document.querySelectorAll('.btn-icon[data-icon]').forEach(el => {
    el.innerHTML = el.getAttribute('data-icon');
  });
</script>

<style>
.hero-section {
  padding: 5rem 0 4rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -200px;
  left: 50%;
  transform: translateX(-50%);
  width: 800px;
  height: 600px;
  background: radial-gradient(ellipse at center, color-mix(in srgb, var(--primary) 12%, transparent) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.venue-badge {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--primary);
  background-color: color-mix(in srgb, var(--primary) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  margin-bottom: 1.5rem;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.25rem);
  color: var(--text);
  max-width: 820px;
  margin: 0 auto 1.75rem;
  line-height: 1.15;
}

.authors {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.25rem 1.5rem;
  margin-bottom: 2rem;
}

.author-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  font-size: 1rem;
  color: var(--text-muted);
}

.author-name {
  color: var(--text);
  font-weight: 500;
  text-decoration: none;
  transition: color 0.2s ease;
}

.author-name:hover {
  color: var(--primary);
}

.author-contact {
  display: inline-block;
  color: var(--text-muted);
  font-size: 0.8rem;
  text-decoration: none;
  transition: color 0.2s ease;
}

.author-contact:hover {
  color: var(--primary);
}

.affiliation-link {
  display: inline-block;
  color: var(--text-muted);
  font-size: 0.8rem;
  text-decoration: none;
  transition: color 0.2s ease;
}

.affiliation-link:hover {
  color: var(--primary);
}
.action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
  margin-bottom: 3.5rem;
}

.teaser-video-wrapper {
  max-width: 860px;
  margin: 0 auto;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid var(--border);
  box-shadow: 0 24px 64px color-mix(in srgb, #000 18%, transparent);
}

.teaser-video {
  width: 100%;
  height: auto;
  display: block;
}

@media (max-width: 640px) {
  .hero-section {
    padding: 3rem 0 2.5rem;
  }
}
</style>
